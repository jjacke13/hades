# --- Telegram front-end (uncomment, set YOUR numeric user id, export TELEGRAM_BOT_TOKEN) ---
# Get an id: message @userinfobot. Non-listed senders are silently ignored. Private chats only (v1): group messages are ignored. Token via env ONLY
# (keep it in a gitignored .env you `source`); it is redacted in session.log.
 #Module = telegram
 #Telegram
 #{
 #  token_env      = TELEGRAM_BOT_TOKEN
 #  allow_users    = 123456789
 #  poll_timeout_s = 50
 #}

# --- Bridge: multi-agent (uncomment on EACH agent; set name/port/peers; export HADES_BRIDGE_SECRET
# in the same gitignored .env as the other secrets — same secret on every fleet member, v1) ---
# A peer request drives a normal turn through THIS agent's own objectives; confirm-gated actions
# are AUTO-DENIED for peers. Shares arrive as PEER.<name>.<key>. host 0.0.0.0 for LAN.
 Module = bridge
 Bridge
 {
   name          = hades1
   host          = 127.0.0.1
   port          = 9090
   secret_env    = HADES_BRIDGE_SECRET
   #share_out     =
   max_hops      = 1
   ask_timeout_s = 180
   #  description         = "hades1 primary agent"  # card persona one-liner (default = name)
   #  discover_interval_s = 300                      # peer-card /card re-pull seconds; 0 = boot pull only
 }
 Peer = hades2 { url = http://127.0.0.1:9091 }
 # A peer with a trust tier — untrusted peers' shared facts are folded as "unverified claim from".
 # NOTE: MUST be a multi-line block — a packed `Peer = x { url = ..  trust = .. }` line fails LOUD
 # (the one-kv-per-line manifest guard). Default trust is "trusted".
 # Peer = watcher
 # {
 #   url   = http://10.0.0.9:9090
 #   trust = untrusted
 # }
 Tool = ask_agent { native = ./build/hades-ask-agent }

# --- Heartbeat: cron self-triggered turns (the agent acts on its own). Module + >=1 Heartbeat
# block. Each entry fires a normal gated turn on its cron schedule (machine-local time). notify=true
# forwards the reply to you (Telegram) UNLESS the agent replies exactly SILENT; notify=false runs a
# silent background task (tool actions are the output). A tick can call any tool (incl. ask_agent);
# confirm-band actions are AUTO-DENIED (no human present); a tick is skipped if a turn is running. ---
# Module = heartbeat
# Heartbeat = monitor
# {
#   schedule = */10 * * * *          # every 10 min. cron: min hour dom month dow (* N A-B */N A,B)
#   prompt   = Check pi0 is reachable and healthy (ask it). Reply exactly SILENT if all is fine.
#   notify   = true                  # needs Module = telegram rostered to actually deliver
# }
# Heartbeat = daily
# {
#   schedule    = 0 6 * * *          # 06:00 daily (machine-local time)
#   prompt_file = prompts/daily_summary.txt   # use prompt_file for long prompts or any with an '='
#   notify      = false
# }

# --- Self-scheduling: let the agent create its own cron/one-shot tasks at runtime (needs Module =
# heartbeat above). Roster the 3 tools to enable. A HUMAN turn may schedule freely; a heartbeat TICK
# may schedule only if allow_self_schedule = true (recursion guard). Tasks persist in cron_store and
# coexist with the static Heartbeat entries above. A task is a PROMPT (to run a command, the prompt
# tells the agent to call run_command). schedule_task takes one of: schedule (cron) / in_minutes / at. ---
# Tool = schedule_task { native = ./build/hades-schedule-task }
# Tool = list_tasks    { native = ./build/hades-list-tasks }
# Tool = cancel_task   { native = ./build/hades-cancel-task }
# Heartbeat
# {
#   cron_store          = .hades/cron.jsonl
#   allow_self_schedule = false        # true = a heartbeat tick may create tasks too
#   max_tasks           = 20
#   min_interval_s      = 60
# }
