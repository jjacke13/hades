# hades reference manifest — the runnable default, with every optional feature included
# below as a commented block you can uncomment per deployment. Every key is documented in
# docs/manifest-reference.md. Rule: ONE key = value per line (a packed line refuses to boot).
# Secrets (API keys, bot tokens, the bridge secret) are env vars ONLY — never written here.
Session
{
  provider       = openai_compat
  endpoint       = https://api.ppq.ai/v1     # any OpenAI-compatible endpoint
  model          = gpt-5.5
  api_key_env    = HADES_API_KEY
  # env_file     = .env   # optional: hades loads this dotenv file at boot (real env wins); keep it gitignored, chmod 600
  price_per_mtok = 5.0
  system_prompt_file = prompts/soul.md   # SOUL — persona/rules, prepended to every turn
  # user_file        = prompts/user.md   # USER — your profile (optional)
  memory_file        = memory/facts.md   # MEMORY — always-on core memory (core_memory edits it; gitignored)
  # memory_char_limit  = 2400   # cap on core memory (over-cap writes list entries to consolidate)
  llm_timeout_s       = 600   # per-call LLM HTTP timeout (cpr). Default 600.
  turn_idle_timeout_s = 900   # run_until idle ceiling (front-ends). Default 900. MUST be > llm_timeout_s.
  sessions_dir         = .hades/sessions   # per-session conversation jsonl dir (--resume reloads it)
  history_budget_chars = 120000   # max chars of history sent per LLM request (full history kept on disk)
}
Module = llm
Module = tool_runner
Module = memory
Module = chat
Module = arbiter
Module = serve
Module = skills
# Module = status   # dim per-turn stats line under each REPL reply (ctx tokens · spend · turn · model)
# --- Auto-extract: after each human turn, a background LLM call harvests durable facts
# (preferences, corrections, standing facts) into archival memory with src:"auto". Costs one
# extra small LLM call per turn, metered into the budget. The AutoExtract block is optional;
# model defaults to the Session model (point it at a cheaper one if your provider has it).
# Module = auto_extract
# AutoExtract
# {
#   model     = gpt-5.5
#   max_facts = 3
#   timeout_s = 60
# }
Tool = fs         { native = ./build/hades-fs-read }
Tool = shell      { native = ./build/hades-shell }
Tool = write_file { native = ./build/hades-write-file }
Tool = list_dir   { native = ./build/hades-list-dir }
Tool = http_fetch { native = ./build/hades-http-fetch }
Tool = save_memory { native = ./build/hades-save-memory }
Tool = core_memory { native = ./build/hades-core-memory }
Tool = use_skill  { native = ./build/hades-use-skill }
Tool = save_skill { native = ./build/hades-save-skill }
Tool = grep       { native = ./build/hades-grep }
Tool = glob       { native = ./build/hades-glob }
Tool = edit_file  { native = ./build/hades-edit-file }
Tool = git_read   { native = ./build/hades-git-read }
Tool = run_command
{
  native    = ./build/hades-run-command
  timeout_s = 600
}
# Tool = session_search { native = ./build/hades-session-search }   # keyword recall over past sessions

# --- MCP servers: one Tool block per SERVER (stdio command or remote URL). Its tools are
# discovered at boot and announced to the model as <block>__<tool>; each call is confirm-gated
# unless listed in capability_policy's mcp_allow. See docs/manifest-reference.md §4.
# Tool = weather { mcp = npx -y @h1deya/mcp-server-weather }
# Tool = linear
# {
#   mcp_url     = https://mcp.example.com/mcp
#   api_key_env = LINEAR_MCP_KEY            # Bearer token env var (optional)
# }

Memory
{
  store = .hades/memory.jsonl
  top_n = 5
}
Skills
{
  dir = skills
}
Arbiter { policy = v1 }
Objective = stay_on_budget   { hard_cap_usd = 1.0 }   # MUST be > 0 (0 blocks everything)
# Capability scopes: deny reads of secrets/system paths, block private/loopback fetch (SSRF),
# allow the workspace, confirm anything out of scope. Registered BEFORE avoid_destructive so a
# hard-veto short-circuits first; avoid_destructive stays as the destructive-pattern backstop.
# MULTI-LINE block (one key=value per line): a packed line would fail enforce_manifest at boot.
Objective = capability_policy
{
  fs_read_allow     = ./workspace ./docs ./manifests ./prompts ./web
  fs_deny           = /etc /root .env secrets/ .ssh/ .git/credentials id_rsa
  fs_write_allow    = ./workspace
  exec_allow        = cmake --build build, ctest --test-dir build
  # Email (skills/email + himalaya): add the two READ prefixes below to let inbox checks run
  # without confirm (unattended heartbeat summaries). Sending stays confirm-band by design (the
  # skill sends via `shell`). CAVEAT on a BRIDGED agent: allow-band reads also apply to peer-driven
  # turns — a peer could read your mail; keep these out of exec_allow on peer-exposed workers.
  # exec_allow      = cmake --build build, ctest --test-dir build, himalaya envelope list, himalaya message read
  # mcp_allow       = weather__get_forecast   # discovered MCP tools allowed WITHOUT confirm (* = all — trusts every server)
  block_private_net = true
  confirm_unscoped  = true
}
Objective = avoid_destructive { veto = true }
Serve
{
  host    = 127.0.0.1
  port    = 8080
  webroot = web
}

# --- Opt-in semantic memory (uncomment the module line AND the Embedding block).
# Backend options for `command`/`endpoint`:
#   - sentence-transformers: provider = subprocess ; command = python3 ./tools/embed_reference.py
#   - ollama:    `ollama pull nomic-embed-text`; provider = http ; endpoint = http://localhost:11434/v1 ; model = nomic-embed-text
#   - llama.cpp: `llama-server --embedding`;       provider = http ; endpoint = http://localhost:8080/v1 (OpenAI-compat /embeddings)
#   - PPQ (remote, reuses your LLM key): provider = http ; endpoint = https://api.ppq.ai/v1
#       (NOT .../embeddings — the provider appends /embeddings) ; model = openai/text-embedding-3-small ;
#       api_key_env = HADES_API_KEY  (embed cost hits your PPQ balance; NOT metered by the budget objective)
# Module = embedding_memory
# Embedding
# {
#   provider           = http
#   endpoint           = https://api.ppq.ai/v1
#   api_key_env        = HADES_API_KEY
#   model              = openai/text-embedding-3-small
#   index_sessions     = true
#   top_n              = 3
#   min_similarity     = 0.45
#   reindex_interval_s = 86400   # daily batch reindex (0 = off)
#   batch_size         = 32
#   timeout_s          = 120
# }

# --- Voice input (STT). Uncomment to let Telegram voice messages be transcribed.
# Stt
# {
#   provider    = http
#   endpoint    = https://api.ppq.ai/v1
#   model       = nova-3                # PPQ default = Deepgram Nova-3
#   api_key_env = HADES_API_KEY
#   language    = en
#   timeout_s   = 60
#   # provider  = command
#   # command   = ./tools/whisper_reference.sh
# }

# --- Voice output (TTS). Uncomment to speak replies to Telegram voice messages (mirror modality:
# a voice message gets a spoken reply; typed messages stay text-only).
# Tts
# {
#   provider    = http
#   endpoint    = https://api.ppq.ai/v1
#   model       = deepgram_aura_2       # PPQ: Deepgram Aura (or eleven_multilingual_v2 / eleven_flash_v2_5)
#   voice       = aura-2-arcas-en       # Aura voices: aura-2-{arcas,thalia,andromeda,helena,apollo,aries}-en
#   api_key_env = HADES_API_KEY
#   max_chars   = 2000                  # Deepgram limit 2000 (ElevenLabs 5000); over -> 422 -> skipped
#   timeout_s   = 60
#   # provider  = command
#   # command   = ./tools/piper_reference.sh
# }

# --- Telegram front-end (uncomment, set YOUR numeric user id, export TELEGRAM_BOT_TOKEN) ---
# Get an id: message @userinfobot. Non-listed senders are silently ignored. Private chats only
# (v1): group messages are ignored. Token via env ONLY (keep it in a gitignored .env you
# `source`); it is redacted in session.log.
# Module = telegram
# Telegram
# {
#   token_env      = TELEGRAM_BOT_TOKEN
#   allow_users    = 123456789
#   poll_timeout_s = 50
# }

# --- Bridge: multi-agent (uncomment on EACH agent; set name/port/peers; export HADES_BRIDGE_SECRET
# in the same gitignored .env as the other secrets — same secret on every fleet member, v1) ---
# A peer request drives a normal turn through THIS agent's own objectives; confirm-gated actions
# are AUTO-DENIED for peers. Shares arrive as PEER.<name>.<key>. host 0.0.0.0 for LAN.
# Module = bridge
# Bridge
# {
#   name          = hades1
#   host          = 127.0.0.1
#   port          = 9090
#   secret_env    = HADES_BRIDGE_SECRET
#   max_hops      = 1
#   ask_timeout_s = 180
#   # share_out           =
#   # description         = "hades1 primary agent"  # card persona one-liner (default = name)
#   # discover_interval_s = 300                      # peer-card /card re-pull seconds; 0 = boot pull only
# }
# Peer = hades2 { url = http://127.0.0.1:9091 }
# A peer with a trust tier — untrusted peers' shared facts are folded as "unverified claim from".
# NOTE: MUST be a multi-line block — a packed `Peer = x { url = ..  trust = .. }` line fails LOUD
# (the one-kv-per-line manifest guard). Default trust is "trusted".
# Peer = watcher
# {
#   url   = http://192.0.2.9:9090
#   trust = untrusted
# }
# Tool = ask_agent { native = ./build/hades-ask-agent }

# --- Heartbeat: cron self-triggered turns (the agent acts on its own). Module + >=1 Heartbeat
# block. Each entry fires a normal gated turn on its cron schedule (machine-local time). notify=true
# forwards the reply to you (Telegram/SimpleX) UNLESS the agent replies exactly SILENT; notify=false
# runs a silent background task (tool actions are the output). A tick can call any tool (incl.
# ask_agent); confirm-band actions are AUTO-DENIED (no human present); a tick is skipped if a turn
# is running. ---
# Module = heartbeat
# Heartbeat = monitor
# {
#   schedule = */10 * * * *          # every 10 min. cron: min hour dom month dow (* N A-B */N A,B)
#   prompt   = Check pi0 is reachable and healthy (ask it). Reply exactly SILENT if all is fine.
#   notify   = true                  # needs Module = telegram (or simplex) rostered to deliver
# }
# Heartbeat = daily
# {
#   schedule    = 0 6 * * *          # 06:00 daily (machine-local time)
#   prompt_file = prompts/daily_summary.txt   # use prompt_file for long prompts or any with an '='
#   notify      = false
# }

# --- Self-scheduling: let the agent create its own cron/one-shot tasks at runtime (needs Module =
# heartbeat above). Roster the 3 tools to enable. A HUMAN turn may schedule freely; a heartbeat TICK
# may schedule only if allow_self_schedule = true (recursion guard). Tasks persist in cron_store and
# coexist with the static Heartbeat entries above. A task is a PROMPT (to run a command, the prompt
# tells the agent to call run_command). schedule_task takes one of: schedule (cron) / in_minutes / at. ---
# Tool = schedule_task { native = ./build/hades-schedule-task }
# Tool = list_tasks    { native = ./build/hades-list-tasks }
# Tool = cancel_task   { native = ./build/hades-cancel-task }
# Heartbeat
# {
#   cron_store          = .hades/cron.jsonl
#   allow_self_schedule = false        # true = a heartbeat tick may create tasks too
#   max_tasks           = 20
#   min_interval_s      = 60
# }

# --- Reactive when= watches: fire a self-turn on a Blackboard condition instead of a schedule
# (needs Module = heartbeat). Edge-triggered (fires once when the condition BECOMES true / value
# changes; re-arms when it stops holding); cooldown_s absorbs flapping; checked ~every 30s, so
# reaction is not instant. `when` XOR `schedule` per entry. The agent can also create watches at
# runtime via schedule_task (when = "KEY changes" etc.). Forms:
#   KEY changes | KEY is <str> | KEY not <str> | KEY above <n> | KEY below <n>
# Heartbeat = budget_watch
# {
#   when       = BUDGET_SPENT_USD above 0.8
#   prompt     = The session budget is nearly spent. Summarize what it went on so far.
#   notify     = true                  # needs Module = telegram (or simplex) rostered to deliver
#   cooldown_s = 3600                  # at most one warning per hour
# }
# Heartbeat = peer_watch
# {
#   when   = PEER.pi0.card changes     # a peer's advertised capabilities changed
#   prompt = pi0's agent card changed. Compare its new capabilities to what you knew and report.
#   notify = true
# }

# --- SimpleX front-end (uncomment; needs a local `simplex-chat -p 5225` daemon with the bot
# profile + /address created once in its CLI — see docs/manifest-reference.md §16). No tokens:
# the daemon's WS API is unauthenticated-by-design, loopback-only. allow_contacts is REQUIRED
# (comma-separated local contact ids and/or exact display names). auto_accept=true is an
# explicit opt-in: with an open address, a stranger can NAME THEMSELVES like an allowlisted
# display name — keep manual acceptance (default) or allowlist by numeric id.
# Module = simplex
# Simplex
# {
#   host           = 127.0.0.1
#   port           = 5225
#   allow_contacts = 2, Alice Example
#   auto_accept    = false
#   # notify_contact = 2   # NOTIFY_USER (heartbeat) delivery target
# }
