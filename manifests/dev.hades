# hades MVP manifest
Session
{
  provider       = openai_compat
  endpoint       = https://api.ppq.ai/v1
  model          = claude-haiku-4.5
  api_key_env    = HADES_API_KEY
  price_per_mtok = 5.0
  system_prompt_file = prompts/soul.md   # SOUL — persona/rules, prepended to every turn
  # user_file        = prompts/user.md   # USER — your profile (optional)
  memory_file        = memory/facts.md   # MEMORY — always-on core memory (pin_fact writes it)
  llm_timeout_s       = 600   # per-call LLM HTTP timeout (cpr). Default 600.
  turn_idle_timeout_s = 900   # run_until idle ceiling (front-ends). Default 900. MUST be > llm_timeout_s.
}
Module = llm
Module = tool_runner
Module = memory
Module = chat
Module = arbiter
Module = serve
Tool = fs         { native = ./build/hades-fs-read }
Tool = shell      { native = ./build/hades-shell }
Tool = write_file { native = ./build/hades-write-file }
Tool = list_dir   { native = ./build/hades-list-dir }
Tool = http_fetch { native = ./build/hades-http-fetch }
Tool = save_memory { native = ./build/hades-save-memory }
Tool = pin_fact    { native = ./build/hades-pin-fact }
Memory
{
  store = .hades/memory.jsonl
  top_n = 5
}
Arbiter { policy = v1 }
Objective = stay_on_budget   { hard_cap_usd = 1.0 }
# Capability scopes: deny reads of secrets/system paths, block private/loopback fetch (SSRF),
# allow the workspace, confirm anything out of scope. Registered BEFORE avoid_destructive so a
# hard-veto short-circuits first; avoid_destructive stays as the destructive-pattern backstop.
# MULTI-LINE block (one key=value per line): a packed line would fail enforce_manifest at boot.
Objective = capability_policy
{
  fs_read_allow     = ./workspace ./docs ./manifests ./prompts ./web
  fs_deny           = /etc /root .env secrets/ .ssh/ .git/credentials id_rsa
  block_private_net = true
  confirm_unscoped  = true
}
Objective = avoid_destructive { veto = true }
Serve
{
  host    = 127.0.0.1
  port    = 8080
  webroot = web
}
