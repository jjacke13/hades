# hades MVP manifest
Session
{
  provider       = openai_compat
  endpoint       = https://api.ppq.ai/v1
  model          = gpt-5.5
  api_key_env    = HADES_API_KEY
  price_per_mtok = 5.0
  system_prompt_file = prompts/soul.md   # SOUL — persona/rules, prepended to every turn
  # user_file        = prompts/user.md   # USER — your profile (optional)
  memory_file        = memory/facts.md   # MEMORY — always-on core memory (pin_fact writes it)
  llm_timeout_s       = 600   # per-call LLM HTTP timeout (cpr). Default 600.
  turn_idle_timeout_s = 900   # run_until idle ceiling (front-ends). Default 900. MUST be > llm_timeout_s.
  sessions_dir         = .hades/sessions   # per-session conversation jsonl dir (--resume reloads it)
  history_budget_chars = 120000   # max chars of history sent per LLM request (full history kept on disk)
}
Module = llm
Module = tool_runner
Module = memory
Module = chat
Module = arbiter
Module = serve
Module = skills
Tool = fs         { native = ./build/hades-fs-read }
Tool = shell      { native = ./build/hades-shell }
Tool = write_file { native = ./build/hades-write-file }
Tool = list_dir   { native = ./build/hades-list-dir }
Tool = http_fetch { native = ./build/hades-http-fetch }
Tool = save_memory { native = ./build/hades-save-memory }
Tool = pin_fact    { native = ./build/hades-pin-fact }
Tool = use_skill  { native = ./build/hades-use-skill }
Tool = save_skill { native = ./build/hades-save-skill }
Tool = grep       { native = ./build/hades-grep }
Tool = glob       { native = ./build/hades-glob }
Tool = edit_file  { native = ./build/hades-edit-file }
Tool = git_read   { native = ./build/hades-git-read }
Tool = run_command
{
  native    = ./build/hades-run-command
  timeout_s = 600
}
Memory
{
  store = .hades/memory.jsonl
  top_n = 5
}
Skills
{
  dir = skills
}
Arbiter { policy = v1 }
Objective = stay_on_budget   { hard_cap_usd = 1.0 }
# Capability scopes: deny reads of secrets/system paths, block private/loopback fetch (SSRF),
# allow the workspace, confirm anything out of scope. Registered BEFORE avoid_destructive so a
# hard-veto short-circuits first; avoid_destructive stays as the destructive-pattern backstop.
# MULTI-LINE block (one key=value per line): a packed line would fail enforce_manifest at boot.
Objective = capability_policy
{
  fs_read_allow     = ./workspace ./docs ./manifests ./prompts ./web
  fs_deny           = /etc /root .env secrets/ .ssh/ .git/credentials id_rsa
  fs_write_allow    = ./workspace
  exec_allow        = cmake --build build, ctest --test-dir build
  block_private_net = true
  confirm_unscoped  = true
}
Objective = avoid_destructive { veto = true }
Serve
{
  host    = 127.0.0.1
  port    = 8080
  webroot = web
}
# --- Opt-in semantic memory (ENABLED below via PPQ; comment `Module = embedding_memory` to
# fall back to keyword-only memory without an embedder). Backend options for `command`/`endpoint`:
#   - sentence-transformers: provider = subprocess ; command = python3 ./tools/embed_reference.py
#   - ollama:    `ollama pull nomic-embed-text`; provider = http ; endpoint = http://localhost:11434/v1 ; model = nomic-embed-text
#   - llama.cpp: `llama-server --embedding`;       provider = http ; endpoint = http://localhost:8080/v1 (OpenAI-compat /embeddings)
#   - PPQ (remote, reuses your LLM key): provider = http ; endpoint = https://api.ppq.ai/v1
#       (NOT .../embeddings — the provider appends /embeddings) ; model = openai/text-embedding-3-small ;
#       api_key_env = HADES_API_KEY  (embed cost hits your PPQ balance; NOT metered by the budget objective)
Module = embedding_memory
Embedding {
  provider           = http
  endpoint           = https://api.ppq.ai/v1
  api_key_env        = HADES_API_KEY
  model              = openai/text-embedding-3-small
  index_sessions     = true
  top_n              = 3
  min_similarity     = 0.45
  reindex_interval_s = 86400   # daily batch reindex (0 = off)
  batch_size         = 32
  timeout_s          = 120
}

