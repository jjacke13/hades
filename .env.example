# hades secrets — copy to .env (gitignored), fill in, chmod 600.
# Load it either way:
#   - source .env            before launching, or
#   - Session { env_file = .env }   and hades loads it at boot (real env wins over the file).
# Format: KEY=VALUE per line; '#' full-line comments; optional `export ` prefix and quotes OK.

# LLM API key — REQUIRED (any OpenAI-compatible endpoint; name set by Session.api_key_env)
HADES_API_KEY=

# Embedding API key — only with `Module = embedding_memory` + provider = http
# (dev.hades points Embedding.api_key_env at HADES_API_KEY instead, so usually not needed)
#HADES_EMBED_KEY=

# Telegram bot token (@BotFather) — only with `Module = telegram`
#TELEGRAM_BOT_TOKEN=

# Shared agent↔agent bridge secret — only with `Module = bridge`; SAME value on every fleet member
#HADES_BRIDGE_SECRET=

# Bearer token for a remote MCP server — name is whatever the Tool block's api_key_env says
#LINEAR_MCP_KEY=
